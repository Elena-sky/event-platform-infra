# gateway-api — copy to gateway.env, do not commit gateway.env

# App
APP_NAME=event-platform-gateway-api
APP_VERSION=0.1.0
APP_ENV=prod
APP_PORT=8000
LOG_LEVEL=INFO
UVICORN_HOST=0.0.0.0

# RabbitMQ connection
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# Events exchange (publish target)
RABBITMQ_EXCHANGE=events.topic
RABBITMQ_EXCHANGE_TYPE=topic

# Bootstrap queue (declares exchange on startup)
RABBITMQ_BOOTSTRAP_QUEUE=events.audit.bootstrap
RABBITMQ_BOOTSTRAP_BINDING_KEY=#

# Management HTTP API (for /observability/broker endpoint)
RABBITMQ_HTTP_API_URL=http://rabbitmq:15672
RABBITMQ_HTTP_API_USER=admin
RABBITMQ_HTTP_API_PASSWORD=admin
RABBITMQ_MONITORED_QUEUES=notification.email,analytics.events

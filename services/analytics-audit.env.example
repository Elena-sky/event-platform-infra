# analytics-audit-service — copy to analytics-audit.env, do not commit analytics-audit.env

# App
APP_NAME=analytics-audit-service
APP_ENV=prod
APP_PORT=8010
LOG_LEVEL=INFO

# RabbitMQ connection
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# Exchange / queue (fan-out consumer — binds to all events via #)
RABBITMQ_EVENTS_EXCHANGE=events.topic
RABBITMQ_QUEUE=analytics.events
RABBITMQ_BINDING_KEYS=#
RABBITMQ_PREFETCH=20

# Audit log (path inside container, backed by Docker volume)
AUDIT_LOG_PATH=/app/data/audit-events.jsonl

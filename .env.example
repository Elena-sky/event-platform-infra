# Copy to ``.env`` and adjust. Do not commit ``.env``.
# Compose interpolates these variables; the same file is passed to the RabbitMQ container via ``env_file``.

# RabbitMQ & Prometheus container arch (optional). Default in compose is linux/amd64.
# Apple Silicon (Docker Desktop): uncomment so brokers are native ARM, not QEMU:
# INFRA_PLATFORM=linux/arm64

RABBITMQ_IMAGE=rabbitmq:3.13-management

# Host ports (container keeps 5672 / 15672 / 15692 internally)
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692

# Prometheus host port (container keeps 9090 internally)
PROMETHEUS_PORT=9090

# Broker credentials (official image variables). Must match gateway / notification ``RABBITMQ_USER`` / ``RABBITMQ_PASSWORD``.
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# Shared Docker network name
EVENT_PLATFORM_NETWORK_NAME=event-platform-net

# Host port for gateway-api (default: 8000)
GATEWAY_PORT=8000

# Image versions (used by docker-compose.yml — production mode).
RETRY_ORCHESTRATOR_VERSION=0.1.0
NOTIFICATION_VERSION=0.1.0
ANALYTICS_AUDIT_VERSION=0.1.0
GATEWAY_VERSION=0.1.0

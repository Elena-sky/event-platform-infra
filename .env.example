# Copy to ``.env`` and adjust. Do not commit ``.env``.
# Compose interpolates these variables; the same file is passed to the RabbitMQ container via ``env_file``.

RABBITMQ_IMAGE=rabbitmq:3.13-management

# Host ports (container keeps 5672 / 15672 internally)
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Broker credentials (official image variables)
RABBITMQ_DEFAULT_USER=user
# Must match gateway ``RABBITMQ_USER`` / ``RABBITMQ_PASSWORD`` when using default local setup
RABBITMQ_DEFAULT_PASS=password

# Shared Docker network name (must match gateway ``docker-compose.yml`` ``external`` name)
EVENT_PLATFORM_NETWORK_NAME=event-platform-net
